{
  "name": "@tlahey/agent-eval",
  "version": "0.1.1-alpha",
  "description": "AI coding agent evaluation framework with Vitest-like DX",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agenteval": "./dist/cli.js"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./llm": {
      "types": "./dist/llm.d.ts",
      "import": "./dist/llm.js",
      "require": "./dist/llm.cjs"
    },
    "./environment": {
      "types": "./dist/environment.d.ts",
      "import": "./dist/environment.js",
      "require": "./dist/environment.cjs"
    },
    "./ledger": {
      "types": "./dist/ledger.d.ts",
      "import": "./dist/ledger.js",
      "require": "./dist/ledger.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "postbuild": "rm -rf ./dist/ui && mkdir -p ./dist/ui && cp -r ../../apps/eval-ui/dist/* ./dist/ui/ 2>/dev/null || true",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "agent",
    "eval",
    "testing",
    "llm",
    "judge"
  ],
  "license": "ISC",
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "ai": "^4.0.0",
    "commander": "^13.0.0",
    "dotenv": "^17.3.1",
    "glob": "^11.0.0",
    "jiti": "^2.4.0",
    "picocolors": "^1.1.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "@vitest/coverage-v8": "^3.2.4",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
